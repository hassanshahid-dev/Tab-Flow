{
    "manifest_version": 3,
    "name": "AI Tabs Manager",
    "version": "1.0",
    "description": "Save and restore browser workspaces.",

    "permissions": [
        "tabs",
        "storage",
        "sidePanel"
    ],

    "host_permissions": [
        "http://localhost:5000/*"
    ],

    "background": {
        "service_worker": "background.js"
    },

    "side_panel": {
        "default_path": "popup.html"
    },

    "action": {
        "default_popup": ""
    }
}